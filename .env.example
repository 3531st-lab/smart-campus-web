# Production login signing secrets. Use long, random values.
AUTH_SECRET=replace-with-a-long-random-secret
SMS_TOKEN_SECRET=replace-with-another-long-random-secret
# MySQL student identity library. DATABASE_URL takes priority when provided.
DATABASE_URL=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=smart_campus
MYSQL_PASSWORD=
MYSQL_DATABASE=smart_campus

# Class group synchronization is dry-run by default. The apply command additionally
# requires CONFIRM_CLASS_SYNC=YES in its process environment.
CONFIRM_CLASS_SYNC=

# Campus chat image stickers. Local development stores converted WebP files under public/uploads/chat-stickers.
# Production should use a private R2 write key and a public custom domain for delivery.
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
R2_CHAT_MEDIA_PREFIX=chat-stickers
CHAT_STICKER_MAX_INPUT_BYTES=4194304
CHAT_STICKER_MAX_OUTPUT_BYTES=1048576
# Comma-separated SHA-256 digests blocked by moderation.
CHAT_BLOCKED_MEDIA_DIGESTS=
# JSON allowlist for licensed network source adapters. Do not add arbitrary remote image hosts.
CHAT_STICKER_SOURCE_ALLOWLIST=[]

# Cloudflare Durable Object realtime gateway. The two secrets must be distinct,
# random values (at least 32 characters) and configured in both the REST API and Worker.
CHAT_REALTIME_URL=
CHAT_REALTIME_TOKEN_SECRET=replace-with-a-long-random-realtime-token-secret
CHAT_REALTIME_INTERNAL_SECRET=replace-with-a-different-long-random-internal-secret
CHAT_REALTIME_TOKEN_TTL_MS=300000
CHAT_REALTIME_PUBLISH_TIMEOUT_MS=2000

# Private campus identity. Configure these in Vercel environment variables.
CAMPUS_USER_SCHOOL=泰州学院
CAMPUS_USER_NAME=
CAMPUS_USER_COLLEGE=经济与管理学院
CAMPUS_USER_MAJOR=数字经济
CAMPUS_USER_CLASS=
CAMPUS_USER_STUDENT_NO=
CAMPUS_USER_PHONE=
CAMPUS_USER_ROLE=student

# SMS provider: development, aliyun, or webhook.
# development shows a local code on the login page.
SMS_PROVIDER=development

# Aliyun SMS (recommended production provider).
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_REGION_ID=cn-hangzhou

# Optional generic SMS gateway webhook.
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
SMS_TEMPLATE_ID=

# Real AI assistant. Keys stay on the server and are never sent to browsers.
# AI_PROVIDER=openai uses the OpenAI Responses API.
# Other values use an OpenAI-compatible /chat/completions endpoint.
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-5.5
AI_MAX_REQUESTS_PER_MINUTE=12
AI_SYSTEM_PROMPT=你是一个能力全面、准确、实用的 AI 助手。请直接解决用户问题，不要把回答局限于校园场景。
